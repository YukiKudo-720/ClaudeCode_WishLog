{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      // Read/Edit/Write：相対・絶対両方のパターンを指定
      "Read(./**)",
      "Read(**)",
      "Edit(./**)",
      "Write(./**)",
      "MultiEdit",
      "Glob",
      "Grep",

      "Bash(node *)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npx *)",

      "Bash(.venv/Scripts/python *)",
      "Bash(.venv/Scripts/pip *)",
      "Bash(.venv/bin/python *)",
      "Bash(.venv/bin/pip *)",
      "Bash(python -m venv .venv)",

      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",

      "Bash(ls ./**)",
      "Bash(cat ./**)",
      "Bash(grep * ./**)",
      "Bash(find . *)",
      "Bash(mkdir *)"
    ],
    "ask": [
      "Bash(npm install *)",
      "Bash(git push *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/credentials*)",
      "Read(**/secrets/**)",
      "Read(//~/.ssh/**)",
      "Read(//~/.aws/**)",
      "Read(//~/.gnupg/**)",
      "Read(//~/.npmrc)",
      "Read(//~/.gitconfig)",
      "Read(//~/.netrc)",
      "Read(//~/.docker/**)",
      "Read(//~/.kube/**)",
      "Read(/proc/**)",
      "Read(\\\\*)",

      "Edit(//**)",
      "Write(//**)",

      "WebFetch",

      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(del *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(ftp *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(telnet *)",
      "Bash(powershell *)",
      "Bash(cmd *)",
      "Bash(wsl *)",
      "Bash(bash -c *)",
      "Bash(sh -c *)",
      "Bash(eval *)",
      "Bash(exec *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kubectl *)",
      "Bash(gem install *)",
      "Bash(cargo install *)",
      "Bash(go install *)",
      "Bash(python -m pip *)",
      "Bash(python3 -m pip *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(mkfs *)",
      "Bash(mount *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(killall *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(env *)",
      "Bash(printenv *)",
      "Bash(export *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  }
}